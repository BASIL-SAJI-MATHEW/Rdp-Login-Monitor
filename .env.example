# BSM environment template for the RDP Login Monitoring & Alert System.
RDP_MONITOR_ENVIRONMENT=production
RDP_MONITOR_MACHINE_NAME=
RDP_MONITOR_WEBHOOK_ENABLED=true
RDP_MONITOR_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url
RDP_MONITOR_WEBHOOK_TIMEOUT_SECONDS=10
RDP_MONITOR_WEBHOOK_RETRY_ATTEMPTS=3
RDP_MONITOR_WEBHOOK_RETRY_BACKOFF_SECONDS=2
RDP_MONITOR_BRUTE_FORCE_ATTEMPTS=5
RDP_MONITOR_BRUTE_FORCE_WINDOW_SECONDS=120
RDP_MONITOR_SUSPICIOUS_IP_FAILURE_THRESHOLD=3
RDP_MONITOR_SUSPICIOUS_IP_WINDOW_SECONDS=300
RDP_MONITOR_ANOMALY_RATE_THRESHOLD=20
RDP_MONITOR_ANOMALY_WINDOW_SECONDS=300
RDP_MONITOR_ALERT_COOLDOWN_SECONDS=300
RDP_MONITOR_ALERT_ON_UNKNOWN_SUCCESS=true
RDP_MONITOR_ALERT_ON_UNKNOWN_FAILURE=false
RDP_MONITOR_WHITELIST_IPS=10.0.0.1,192.168.1.10
RDP_MONITOR_WHITELIST_USERS=administrator,svc_rdp_monitor
RDP_MONITOR_LOG_DIR=logs
RDP_MONITOR_LOG_LEVEL=INFO
RDP_MONITOR_LOG_MAX_BYTES=10485760
RDP_MONITOR_LOG_BACKUP_COUNT=5
RDP_MONITOR_POLL_INTERVAL_SECONDS=2
RDP_MONITOR_BATCH_SIZE=64
RDP_MONITOR_ONLY_RDP_LOGONS=true
RDP_MONITOR_START_FROM_LATEST=true
RDP_MONITOR_ERROR_BACKOFF_SECONDS=5
